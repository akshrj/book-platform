---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav-container">
      <a href="/" class="logo">BookMatrix</a>
      <div class="nav-links">
        <a href="/reviews">Reviews</a>
        <a href="/lists">Curated Lists</a>
      </div>
    </nav>
    <main class="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #fcfbf9;
    --text-color: #1a1a1a;
    --accent-color: #2b5c8f;
    --border-color: #e5e0d8;
  }
  
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Georgia, serif;
    line-height: 1.6;
    padding: 0 1rem;
  }

  .nav-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .logo { font-weight: 700; text-decoration: none; color: var(--text-color); font-size: 1.25rem; }
  .nav-links a { margin-left: 1rem; text-decoration: none; color: var(--accent-color); font-weight: 500; }

  .main-content {
    max-width: 800px;
    margin: 2rem auto;
    width: 100%;
  }

  /* Responsive Text Utilities */
  h1 { font-size: 2.25rem; margin-bottom: 1.5rem; line-height: 1.2; }
  h2 { font-size: 1.75rem; margin-bottom: 1rem; }
  p { margin-bottom: 1.25rem; font-size: 1.1rem; }

  @media (max-width: 600px) {
    h1 { font-size: 1.75rem; }
    h2 { font-size: 1.4rem; }
    p { font-size: 1rem; }
    .nav-container { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>